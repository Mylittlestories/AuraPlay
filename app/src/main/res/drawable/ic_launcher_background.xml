<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon background for AuraPlay.

    A deep navy → purple → electric-blue linear gradient with two faint
    decorative vinyl rings. Vector + aapt:gradient so the launcher scales
    it to any density without losing fidelity.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:startColor="#FF1A1A2E"
                android:centerColor="#FF3A1B6B"
                android:endColor="#FF2196F3" />
        </aapt:attr>
    </path>

    <!-- Subtle decorative vinyl-ring hint (very low opacity) -->
    <path
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.6"
        android:fillColor="#00000000"
        android:pathData="M54,54m-40,0a40,40 0,1 1,80 0a40,40 0,1 1,-80 0" />
    <path
        android:strokeColor="#22FFFFFF"
        android:strokeWidth="0.6"
        android:fillColor="#00000000"
        android:pathData="M54,54m-46,0a46,46 0,1 1,92 0a46,46 0,1 1,-92 0" />
</vector>
